{
  "root": true,
  "ignorePatterns": [
    "dist/",
    "node_modules/",
    "projects/libs/api-client/src/lib/generated/",
    "**/*.d.ts"
  ],
  "overrides": [
    {
      "files": ["*.ts"],
      "parserOptions": {
        "project": [
          "./tsconfig.json",
          "./projects/shell/tsconfig.app.json",
          "./projects/shell/tsconfig.spec.json",
          "./projects/libs/core/tsconfig.lib.json",
          "./projects/libs/core/tsconfig.spec.json",
          "./projects/libs/ui-kit/tsconfig.lib.json",
          "./projects/libs/ui-kit/tsconfig.spec.json",
          "./projects/libs/api-client/tsconfig.lib.json",
          "./projects/libs/api-client/tsconfig.spec.json",
          "./projects/libs/template-editor/tsconfig.lib.json",
          "./projects/libs/template-editor/tsconfig.spec.json",
          "./projects/libs/questionnaire-runner/tsconfig.lib.json",
          "./projects/libs/questionnaire-runner/tsconfig.spec.json"
        ]
      },
      "extends": [
        "eslint:recommended",
        "plugin:@typescript-eslint/recommended",
        "plugin:@angular-eslint/recommended",
        "plugin:@angular-eslint/template/process-inline-templates"
      ],
      "rules": {
        "@angular-eslint/component-selector": [
          "error",
          { "type": "element", "style": "kebab-case" }
        ],
        "@angular-eslint/directive-selector": [
          "error",
          { "type": "attribute", "style": "camelCase" }
        ],
        "@typescript-eslint/no-unused-vars": [
          "warn",
          { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }
        ],
        "@typescript-eslint/no-explicit-any": "warn"
      }
    },
    {
      "files": ["projects/shell/**/*.ts"],
      "rules": {
        "@angular-eslint/component-selector": [
          "error",
          { "type": "element", "style": "kebab-case", "prefix": "tm" }
        ],
        "@angular-eslint/directive-selector": [
          "error",
          { "type": "attribute", "style": "camelCase", "prefix": "tm" }
        ]
      }
    },
    {
      "files": ["projects/libs/core/**/*.ts"],
      "rules": {
        "@angular-eslint/component-selector": [
          "error",
          { "type": "element", "style": "kebab-case", "prefix": "tmc" }
        ],
        "@angular-eslint/directive-selector": [
          "error",
          { "type": "attribute", "style": "camelCase", "prefix": "tmc" }
        ]
      }
    },
    {
      "files": ["projects/libs/ui-kit/**/*.ts"],
      "rules": {
        "@angular-eslint/component-selector": [
          "error",
          { "type": "element", "style": "kebab-case", "prefix": "tmu" }
        ],
        "@angular-eslint/directive-selector": [
          "error",
          { "type": "attribute", "style": "camelCase", "prefix": "tmu" }
        ]
      }
    },
    {
      "files": ["projects/libs/template-editor/**/*.ts"],
      "rules": {
        "@angular-eslint/component-selector": [
          "error",
          { "type": "element", "style": "kebab-case", "prefix": "tme" }
        ],
        "@angular-eslint/directive-selector": [
          "error",
          { "type": "attribute", "style": "camelCase", "prefix": "tme" }
        ]
      }
    },
    {
      "files": ["projects/libs/questionnaire-runner/**/*.ts"],
      "rules": {
        "@angular-eslint/component-selector": [
          "error",
          { "type": "element", "style": "kebab-case", "prefix": "tmq" }
        ],
        "@angular-eslint/directive-selector": [
          "error",
          { "type": "attribute", "style": "camelCase", "prefix": "tmq" }
        ]
      }
    },
    {
      "files": ["projects/libs/api-client/**/*.ts"],
      "rules": {
        "@angular-eslint/component-selector": [
          "error",
          { "type": "element", "style": "kebab-case", "prefix": "tma" }
        ],
        "@angular-eslint/directive-selector": [
          "error",
          { "type": "attribute", "style": "camelCase", "prefix": "tma" }
        ]
      }
    },
    {
      "files": ["*.html"],
      "extends": [
        "plugin:@angular-eslint/template/recommended",
        "plugin:@angular-eslint/template/accessibility"
      ],
      "rules": {
        "@angular-eslint/template/label-has-associated-control": [
          "error",
          {
            "controlComponents": [
              "p-inputText",
              "p-dropdown",
              "p-inputNumber",
              "p-multiSelect",
              "p-chips",
              "p-calendar",
              "p-checkbox",
              "p-radioButton",
              "p-selectButton",
              "p-inputSwitch"
            ]
          }
        ]
      }
    }
  ]
}
